{
  "manifest_version": 3,
  "name": "Boss Hunter - BOSS直聘求职助手",
  "version": "1.0.0",
  "description": "BOSS直聘自动打招呼、批量沟通、岗位智能过滤与投递统计助手，稳定运行于 Edge / Chrome。",
  "default_locale": "zh_CN",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Boss Hunter 求职助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.zhipin.com/*",
    "https://*.zhipin.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.zhipin.com/*",
        "https://*.zhipin.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/content.css"],
      "matches": ["https://*.zhipin.com/*"]
    }
  ]
}
